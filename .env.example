# Glow-Vera Production Environment Variables Template
# Copy this file to .env and fill in the values

# Flask Settings
FLASK_APP=app.py
FLASK_ENV=production
SECRET_KEY=generate_a_secure_random_key_here
DEBUG=False

# Database Settings
# For SQLite on cPanel, use an absolute path for reliability
# Example: sqlite:////home/username/glow-vera/instance/glowvera.db
SQLALCHEMY_DATABASE_URI=sqlite:///glowvera.db

# Domain Settings
PREFERRED_URL_SCHEME=https
